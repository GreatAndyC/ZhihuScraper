# 知乎 Cookie（推荐填写，否则很多接口会 403）
# 登录知乎后：
#   1. 按 F12 打开开发者工具
#   2. 切换到 Network 标签
#   3. 刷新页面，点击任意一个请求
#   4. 在 Request Headers 中找到 Cookie 字段，复制全部内容
#   5. 粘贴到下面（很长，一行，不能换行）
# 注意：
#   - 必须复制完整 Cookie 请求头，不要只复制其中一段
#   - Cookie 过期后需要重新登录知乎并重新复制
#   - 不要把真实 Cookie 提交到 GitHub
ZHIHU_COOKIE=

# 基础请求间隔（秒）
REQUEST_DELAY_MIN=1
REQUEST_DELAY_MAX=2

# 浏览器接口请求间隔（秒）
BROWSER_DELAY_MIN=0.4
BROWSER_DELAY_MAX=0.8

# 保守模式请求间隔（秒）
CONSERVATIVE_REQUEST_DELAY_MIN=2.0
CONSERVATIVE_REQUEST_DELAY_MAX=4.0
CONSERVATIVE_BROWSER_DELAY_MIN=1.2
CONSERVATIVE_BROWSER_DELAY_MAX=2.4

# 导出 HTML 时离线图片下载间隔（秒）
ASSET_DOWNLOAD_DELAY_MIN=0.15
ASSET_DOWNLOAD_DELAY_MAX=0.35
CONSERVATIVE_ASSET_DOWNLOAD_DELAY_MIN=0.6
CONSERVATIVE_ASSET_DOWNLOAD_DELAY_MAX=1.2

# 请求超时（秒）
REQUEST_TIMEOUT=30

# 问题回答分批保存大小
QUESTION_BATCH_SIZE=50

# GUI 端口（可选）
# GUI_PORT=8080
